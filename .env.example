# Example environment variables for CodeAlpha_URL_Shortener
# Copy this file to `.env` and fill in real values before running.

MONGO_URI=mongodb+srv://<username>:<password>@cluster0.mongodb.net/<dbname>?retryWrites=true&w=majority
PORT=5000
BASE_URL=http://127.0.0.1:5000

# Notes:
# - If your MongoDB password contains special characters (e.g. @, :), URL-encode them
#   (for example, @ -> %40). See https://docs.mongodb.com/manual/reference/connection-string/ for details.